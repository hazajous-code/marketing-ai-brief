# Marketing AI Brief — Email Newsletter Settings
# Copy this file to .env and fill in your credentials.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@company.com

# GitHub Pages 정적 사이트 — 구독 폼 (publish.py 빌드 시 HTML에 반영)
# Formspree 등 무료 폼: https://formspree.io 에서 엔드포인트 생성 후 전체 URL
# MARKETING_BRIEF_FORMSPREE_ACTION=https://formspree.io/f/xxxxxxxx
# 제출 후 돌아올 GitHub Pages URL (선택)
# MARKETING_BRIEF_PAGES_URL=https://username.github.io/marketing-ai-brief/
# 또는 Streamlit 앱으로 열기 (이메일을 쿼리로 전달)
# MARKETING_BRIEF_STREAMLIT_URL=http://192.168.x.x:8501
# 또는 수신 전용 메일로 mailto 열기
# MARKETING_BRIEF_SUBSCRIBE_MAILTO=newsletter-admin@company.com
